{
  "name": "pay-outbox-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "hyuk",
    "database.password": "${DATABASE_PASSWORD}",
    "database.dbname": "delivery_eum",
    "database.server.name": "pay",
    "table.include.list": "public.pay_outbox",
    "topic.prefix": "pay-events",
    "plugin.name": "pgoutput",
    "slot.name": "pay_outbox_slot",
    "snapshot.mode": "never"
  }
}
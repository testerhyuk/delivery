{
  "name": "seller-outbox-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "hyuk",
    "database.password": "${DATABASE_PASSWORD}",
    "database.dbname": "delivery_eum",
    "database.server.name": "seller",
    "table.include.list": "public.seller_outbox",
    "topic.prefix": "seller-events",
    "plugin.name": "pgoutput",
    "slot.name": "seller_outbox_slot",
    "snapshot.mode": "never"
  }
}